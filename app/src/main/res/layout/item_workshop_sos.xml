<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="14dp"
    android:layout_margin="10dp"
    android:background="@drawable/bg_card_rounded"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- HEADER -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/imgAvatar"
            android:src="@drawable/ic_user"
            android:layout_width="48dp"
            android:layout_height="48dp"/>


        <LinearLayout
            android:orientation="vertical"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtRiderName"
                android:text="Rider Name"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtDistance"
                android:text="2.3 km • Now"
                android:textSize="12sp"
                android:textColor="#666"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtProblemType"
            android:text="Flat Tire"
            android:textColor="#FFFFFF"
            android:padding="6dp"
            android:background="@drawable/bg_red_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- PROBLEM -->
    <TextView
        android:id="@+id/txtProblem"
        android:text="Front tire completely flat"
        android:layout_marginTop="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- VEHICLE -->
    <TextView
        android:id="@+id/txtVehicle"
        android:text="Yamaha LC135"
        android:textSize="12sp"
        android:textColor="#444"
        android:layout_marginTop="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txtAddress"
        android:text="📍 Address"
        android:textSize="12sp"
        android:textColor="#666"
        android:layout_marginTop="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- ACTION -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <Button
            android:id="@+id/btnAccept"
            android:text="Accept"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1E88E5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnDecline"
            android:text="Decline"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E53935"
            android:layout_marginStart="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</LinearLayout>