<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F1F5F9"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITLE -->
        <TextView
            android:text="Edit Workshop Profile"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- PROFILE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- PROFILE IMAGE -->
                <ImageView
                    android:id="@+id/imgProfile"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_user"
                    android:background="@drawable/bg_circle_gray"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:text="Tap image to change"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:gravity="center"
                    android:layout_marginBottom="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- NAME -->
                <EditText
                    android:id="@+id/edtName"
                    android:hint="Workshop Name"
                    android:background="@drawable/bg_input"
                    android:padding="14dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- PHONE -->
                <EditText
                    android:id="@+id/edtPhone"
                    android:hint="Phone Number"
                    android:inputType="phone"
                    android:background="@drawable/bg_input"
                    android:padding="14dp"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- ADDRESS -->
                <EditText
                    android:id="@+id/edtAddress"
                    android:hint="Workshop Address"
                    android:background="@drawable/bg_input"
                    android:padding="14dp"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <!-- LOCATION -->
                <Button
                    android:id="@+id/btnPickLocation"
                    android:text="📍 Pick Location on Map"
                    android:textAllCaps="false"
                    android:backgroundTint="#C4C8D0"
                    android:textColor="#111827"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"/>

                <!-- WORKING HOURS -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/edtOpenTime"
                        android:hint="Open Time"
                        android:background="@drawable/bg_input"
                        android:layout_weight="1"
                        android:padding="12dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp"/>

                    <EditText
                        android:id="@+id/edtCloseTime"
                        android:hint="Close Time"
                        android:background="@drawable/bg_input"
                        android:layout_weight="1"
                        android:padding="12dp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- SERVICES -->
                <TextView
                    android:text="Services Offered"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <CheckBox
                        android:id="@+id/cbTire"
                        android:text="Tire Repair"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <CheckBox
                        android:id="@+id/cbOil"
                        android:text="Oil Change"
                        android:layout_marginStart="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <CheckBox
                        android:id="@+id/cbBattery"
                        android:text="Battery Jumpstart"
                        android:layout_marginStart="12dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- SAVE -->
                <Button
                    android:id="@+id/btnSave"
                    android:text="Save Changes"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#2563EB"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>