<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_blue">

    <!-- ================= LOGO SECTION ================= -->
    <LinearLayout
        android:id="@+id/layoutLogo"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_alignParentTop="true"
        android:layout_marginTop="56dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/imgLogo2"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginBottom="5dp"
            android:src="@drawable/logo2"
            android:scaleType="fitCenter"
            android:contentDescription="ResQRide Logo"/>

        <TextView
            android:text="Workshop Login"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- ================= LOGIN CARD ================= -->
    <LinearLayout
        android:id="@+id/layoutLoginCard"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_white_card"
        android:layout_below="@id/layoutLogo"
        android:layout_marginTop="32dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- EMAIL -->
        <EditText
            android:id="@+id/edtEmail"
            android:hint="Email"
            android:inputType="textEmailAddress"
            android:autofillHints="emailAddress"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- PASSWORD -->
        <EditText
            android:id="@+id/edtPassword"
            android:hint="Password"
            android:inputType="textPassword"
            android:autofillHints="password"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- FORGOT PASSWORD -->
        <TextView
            android:id="@+id/txtForgot"
            android:text="Forgot Password?"
            android:textColor="#6A5AE0"
            android:textSize="14sp"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- LOGIN BUTTON -->
        <Button
            android:id="@+id/btnLogin"
            android:text="Login"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#F2C94C"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <!-- DIVIDER -->
        <TextView
            android:text="────────  OR  ────────"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:layout_marginVertical="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- GUEST BUTTON -->
        <Button
            android:id="@+id/btnGuest"
            android:text="Continue as Guest"
            android:textAllCaps="false"
            android:backgroundTint="#E0E0E0"
            android:layout_width="match_parent"
            android:layout_height="48dp"/>

        <!-- REGISTER -->
        <TextView
            android:id="@+id/txtRegister"
            android:text="Don’t have an account? Register Workshop"
            android:textColor="#6A5AE0"
            android:textStyle="bold"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</RelativeLayout>