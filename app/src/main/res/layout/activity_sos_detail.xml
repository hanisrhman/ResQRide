<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F3F4F6"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- TITLE -->
        <TextView
            android:text="SOS Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#111827"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>


        <!-- CARD -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_card_rounded"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Problem -->
            <TextView
                android:text="Problem"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtProblem"
                android:text="-"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Rider -->
            <TextView
                android:text="Rider"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtRider"
                android:text="-"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Vehicle Model -->
            <TextView
                android:text="Vehicle Model"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtVehicleModel"
                android:text="-"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Plate -->
            <TextView
                android:text="Plate Number"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtPlate"
                android:text="-"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Workshop -->
            <TextView
                android:text="Workshop"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtWorkshop"
                android:text="-"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Payment -->
            <TextView
                android:text="Payment Method"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtPayment"
                android:text="-"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Cost -->
            <TextView
                android:text="Cost"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtCost"
                android:text="-"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Rating -->
            <TextView
                android:text="Rating"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtRating"
                android:text="-"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Review -->
            <TextView
                android:text="Review"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtReview"
                android:text="-"
                android:layout_marginBottom="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Time -->
            <TextView
                android:text="Time"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/txtTime"
                android:text="-"
                android:layout_marginBottom="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


            <!-- Status -->
            <TextView
                android:id="@+id/txtStatus"
                android:text="STATUS"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:padding="6dp"
                android:background="@drawable/bg_status_completed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>


        <!-- Receipt Button -->
        <Button
            android:id="@+id/btnReceipt"
            android:text="View Receipt"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2563EB"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="48dp"/>

    </LinearLayout>

</ScrollView>